{
  "name": "document-generation-platform",
  "version": "1.0.0",
  "description": "Production-ready scalable backend for massive PDF generation",
  "private": true,
  "main": "dist/src/server.js",
  "license": "MIT",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "start:worker": "node dist/src/workers/queue.worker.js",
    "stack:up": "node scripts/docker-runner.js up --build",
    "stack:down": "node scripts/docker-runner.js down",
    "stack:logs": "node scripts/docker-runner.js logs -f",
    "lint": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand tests/unit",
    "test:integration": "jest --runInBand tests/integration",
    "benchmark": "tsx scripts/benchmark.ts",
    "profile": "node --cpu-prof --heap-prof dist/src/server.js"
  },
  "dependencies": {
    "@types/express": "^5.0.1",
    "bull": "^4.16.5",
    "compression": "^1.8.0",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.4.2",
    "mongodb": "^6.15.0",
    "pdfkit": "^0.16.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "prom-client": "^15.1.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/pdfkit": "^0.17.2",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^29.7.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.2.6",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
