NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://mongodb:27017/document-platform
REDIS_URL=redis://redis:6379
DB_NAME=document-platform
GRIDFS_BUCKET=documents
QUEUE_NAME=document-generation
DLQ_NAME=document-generation-dlq
WORKER_CONCURRENCY=16
API_CLUSTER_WORKERS=2
QUEUE_BACKPRESSURE_LIMIT=5000
PDF_TIMEOUT_MS=5000
EXTERNAL_CALL_TIMEOUT_MS=800
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
LOG_LEVEL=info
ENABLE_SWAGGER=true
